<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{featureSlug}}</title>
  <link rel="stylesheet" href="./styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family={{fontFamilyUrlSafe}}:wght@400;600;700;900&display=swap"
    rel="stylesheet"
  />
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
</head>
<body>
  <main
    data-composition-id="{{compositionId}}"
    data-width="{{width}}"
    data-height="{{height}}"
    data-fps="30"
    data-duration="{{durationSeconds}}"
    data-aspect="{{aspect}}"
  >
    <!-- Scene clips - populated by the skill from the approved scene plan.
         Order matches story.scenes; each clip carries its own data-duration.
         Confirm clip include syntax against the running hyperframes-cli output
         (read the init-generated index.html and mirror its include shape). -->
{{sceneIncludes}}
  </main>
</body>
</html>
